    "import random\n",
    "\n",
    "# usamos el random de python para las simulaciones\n",
    "random.seed(2026)\n",
    "N_REPETICIONES = 10000\n",
    "\n",
    "# inicializamos el contador de coincidencias para exactamente 2 caras\n",
    "coincidencias_2_caras = 0\n",
    "\n",
    "nuevas_prob = [0.4, 0.6]\n",
    "\n",
    "# se realiza un for para simular los lanzamientos de las monedas\n",
    "for i in range(N_REPETICIONES):\n",
    "    # Lanzamos 3 monedas una por una 1 = cara y 0 = cruz\n",
    "    monedas = random.choices([0, 1], weights=nuevas_prob, k=3)\n",
    "\n",
    "    \n",
    "    # se suman los intentos para ver cuántas caras salieron\n",
    "    total_caras = sum(monedas)\n",
    "    \n",
    "    # Si fueron exactamente 2, contamos una coincidencia de exactamente 2 caras\n",
    "    if total_caras == 2:\n",
    "        coincidencias_2_caras += 1\n",
    "\n",
    "# Calculamos el promedio\n",
    "Prob_incisoA = coincidencias_2_caras / N_REPETICIONES\n",
    "\n",
    "print(f'La probabilidad de obtener exactamente 2 caras es: {Prob_incisoA:.4f}')"
   ]
  }
