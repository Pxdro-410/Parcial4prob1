    "import random\n",
    "\n",
    "# se usa la semilla 2026 y las 10000 repeticiones \n",
    "random.seed(2026)\n",
    "N_REPETICIONES = 10000\n",
    "\n",
    "# guardamos el total de caras que salieron en cada juego para luego sacar el promedio\n",
    "suma_total_de_caras = 0\n",
    "\n",
    "for i in range(N_REPETICIONES):\n",
    "    # Lanzamos las 3 monedas 1 para cara y 0 para cruz\n",
    "    moneda1 = random.randint(0, 1)\n",
    "    moneda2 = random.randint(0, 1)\n",
    "    moneda3 = random.randint(0, 1)\n",
    "    \n",
    "    # cuantas caras salieron en este juego (numero de X)\n",
    "    caras_este_juego = (moneda1 + moneda2 + moneda3)**2\n",
    "    \n",
    "    # agregamos las caras de este juego a la suma total para luego sacar el promedio\n",
    "    suma_total_de_caras += caras_este_juego\n",
    "\n",
    "# El Valor Esperado E[X] es el promedio de caras por juego\n",
    "valor_esperado_X = suma_total_de_caras / N_REPETICIONES\n",
    "\n",
    "\n",
    "print(f\"E[X] = {valor_esperado_X:.4f}\")"
